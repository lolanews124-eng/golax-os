# ---------------------------------------------------------------------------
# Golax Prospect AI OS - Environment Variables
# Copy this file to ".env" and fill in real values.
# ---------------------------------------------------------------------------

# --- Database (PostgreSQL) ---
# Local example: postgresql://postgres:postgres@localhost:5432/golax?schema=public
# Neon/Supabase: paste their connection string (must include sslmode=require)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/golax?schema=public"

# --- API server ---
API_PORT=4000
NODE_ENV=development
# Comma separated list of allowed frontend origins
CORS_ORIGIN="http://localhost:3000"

# --- Auth (JWT) ---
# Generate strong random strings, e.g. `openssl rand -hex 32`
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# --- External APIs (placeholders, fill later) ---
# Serper API for business/website discovery: https://serper.dev
SERPER_API_KEY=""
# Google Gemini API for AI analysis + outreach: https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"

# --- Worker ---
# Max concurrent companies processed in the audit pipeline
WORKER_CONCURRENCY=3
# Lighthouse can be heavy; disable to skip technical audits during local dev
ENABLE_LIGHTHOUSE=true

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL="http://localhost:4000"
